<body>
    <header style="background:#1A1A1A; color:#fff; padding:20px; border-bottom:5px solid #F7D100; text-align:center;">
        <h1 style="color:#F7D100; margin:0;">J. Worden & Sons Asphalt Paving</h1>
        <p style="margin:5px 0;">4th-Generation Paving Authority • Est. 1984</p>
        <p><strong>Chester HQ:</strong> 1601 Ware Bottom Springs Rd, Suite 214, Chester, VA 23836</p>
        <a href="tel:8044461296" style="color:#F7D100; font-size:1.5rem; text-decoration:none; font-weight:800;">📞 (804) 446-1296</a>
    </header>

    <section id="services" style="padding:40px 10%; text-align:center;">
        <h2>Our Premium Paving Services</h2>
        <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap:20px;">
            <div style="border:1px solid #ddd; padding:20px;"><h3>Asphalt Driveways</h3><p>Custom residential paving.</p></div>
            <div style="border:1px solid #ddd; padding:20px;"><h3>Commercial Lots</h3><p>KFC, Wendy's, and Retail.</p></div>
            <div style="border:1px solid #ddd; padding:20px;"><h3>Sealcoating</h3><p>Industrial-grade protection.</p></div>
