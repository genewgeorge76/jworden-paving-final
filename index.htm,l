    <section id="contact" style="background:#f4f4f4; padding:50px 10%; text-align:center;">
        <h2>Request a Free Estimate</h2>
        <form action="https://app.kickserv.com/account/60655/leads" method="POST" style="max-width:500px; margin:auto; display:flex; flex-direction:column; gap:10px;">
            <input type="text" name="customer[first_name]" placeholder="First Name" required style="padding:10px;">
            <input type="text" name="customer[last_name]" placeholder="Last Name" required style="padding:10px;">
            <input type="email" name="customer[email]" placeholder="Email" required style="padding:10px;">
            <input type="tel" name="customer[phone]" placeholder="Phone Number" required style="padding:10px;">
            <input type="text" name="customer[service_address]" placeholder="Job Address" required style="padding:10px;">
            <textarea name="job[description]" placeholder="Project Details" style="padding:10px; height:100px;"></textarea>
            <button type="submit" style="background:#F7D100; font-weight:800; padding:15px; border:none; cursor:pointer;">CONNECT TO KICKSERV DASHBOARD →</button>
