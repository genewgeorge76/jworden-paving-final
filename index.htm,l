<section id="contact" style="background:#f4f4f4; padding:60px 10%; text-align:center;">
    <div style="max-width:550px; margin:auto; background:#fff; padding:40px; border-top:8px solid #F7D100; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
